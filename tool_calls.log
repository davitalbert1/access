, GL_FALSE, glm::value_ptr(mvp));\r\n    glUniform4f(GetUniform(wireShader, \"uColor\"), 0.8f, 0.2f, 0.2f, 1.0f); // Default red wireframe\r\n    mesh.DrawLines();\r\n}\r\n\r\nvoid Renderer::DrawWireColor(const MeshVAO& mesh, const glm::mat4& mvp, const glm::vec4& color) {\r\n    UseShaderProgram(wireShader);\r\n    glUniformMatrix4fv(GetUniform(wireShader, \"uMVP\"), 1, GL_FALSE, glm::value_ptr(mvp));\r\n    glUniform4fv(GetUniform(wireShader, \"uColor\"), 1, glm::value_ptr(color));\r\n    mesh.DrawLines();\r\n}\r\n\r\nvoid Renderer::DrawLine(const glm::vec3& p1, const glm::vec3& p2, const glm::vec4& color, const glm::mat4& view, const glm::mat4& proj) {\r\n    UseShaderProgram(wireShader);\r\n    glm::mat4 mvp = proj * view;\r\n    glUniformMatrix4fv(GetUniform(wireShader, \"uMVP\"), 1, GL_FALSE, glm::value_ptr(mvp));\r\n    glUniform4fv(GetUniform(wireShader, \"uColor\"), 1, glm::value_ptr(color));\r\n\r\n    static GLuint lineVAO = 0, lineVBO = 0;\r\n    if (lineVAO == 0) {\r\n        glGenVertexArrays(1, &lineVAO);\r\n        glGenBuffers(1, &lineVBO);\r\n        glBindVertexArray(lineVAO);\r\n        glBindBuffer(GL_ARRAY_BUFFER, lineVBO);\r\n        glBufferData(GL_ARRAY_BUFFER, 6 * sizeof(float), nullptr, GL_DYNAMIC_DRAW);\r\n        glEnableVertexAttribArray(0);\r\n        glVertexAttribPointer(0, 3, GL_FLOAT, GL_FALSE, 3 * sizeof(float), (void*)0);\r\n        glBindVertexArray(0);\r\n    }\r\n    float vertices[6] = { p1.x, p1.y, p1.z, p2.x, p2.y, p2.z };\r\n    glBindVertexArray(lineVAO);\r\n    glBindBuffer(GL_ARRAY_BUFFER, lineVBO);\r\n    glBufferSubData(GL_ARRAY_BUFFER, 0, 6 * sizeof(float), vertices);\r\n    glLineWidth(2.0f);\r\n    glDrawArrays(GL_LINES, 0, 2);\r\n    glBindVertexArray(0);\r\n}\r\n\r\nvoid Renderer::BindMaterial(SceneObject* obj) {\r\n    SetBool(shaderProg, \"uHasTex\", !obj->texturePath.empty());\r\n    SetBool(shaderProg, \"uIsSprite\", obj->type == ObjectType::Object2D);\r\n    SetFloat(shaderProg, \"uMetallic\", obj->metallic);\r\n    SetFloat(shaderProg, \"uRoughness\", obj->roughness);\r\n\r\n    SetInt(shaderProg, \"uSpriteAtlasEnabled\", obj->spriteAtlasEnabled ? 1 : 0);\r\n    SetInt(shaderProg, \"uSpriteCols\", obj->spriteCols);\r\n    SetInt(shaderProg, \"uSpriteRows\", obj->spriteRows);\r\n    SetInt(shaderProg, \"uSpriteIndex\", obj->spriteIndex);\r\n\r\n    if (!obj->texturePath.empty()) {\r\n        GLuint tex = this->LoadTexture(obj->texturePath);\r\n        glActiveTexture(GL_TEXTURE0);\r\n        glBindTexture(GL_TEXTURE_2D, tex);\r\n        SetInt(shaderProg, \"uTex\", 0);\r\n    }\r\n}\r\n\r\nvoid Renderer::SetTransforms(const glm::mat4& model, const glm::mat4& mvp) {\r\n    glUniformMatrix4fv(GetUniform(shaderProg, \"uModel\"), 1, GL_FALSE, glm::value_ptr(model));\r\n    glUniformMatrix4fv(GetUniform(shaderProg, \"uMVP\"), 1, GL_FALSE, glm::value_ptr(mvp));\r\n}\r\n\r\nvoid Renderer::RenderMesh(MeshVAO& mesh, SceneObject* obj, const glm::mat4& model, const glm::mat4& mvp,\r\n                          const glm::vec4& color, float alpha, bool selected) {\r\n    std::shared_ptr<IRHIShader> customShader = nullptr;\r\n    if (obj && obj->materialInstance && obj->materialInstance->parent && obj->materialInstance->parent->shader) {\r\n        customShader = obj->materialInstance->parent->shader;\r\n    }\r\n\r\n    // Registra métricas de draw calls e vértices/índices\r\n    MetricsSystem::Get().AddDrawCall(mesh.indexCount / 3, mesh.indexCount);\r\n\r\n    if (customShader) {\r\n        obj->materialInstance->Apply();\r\n        customShader->SetMat4(\"uModel\", model);\r\n        customShader->SetMat4(\"uMVP\", mvp);\r\n        customShader->SetVec4(\"uColor\", color);\r\n        customShader->SetFloat(\"uAlpha\", alpha);\r\n        customShader->SetVec3(\"uCameraPos\", cachedCameraPos);\r\n        customShader->SetVec3(\"uGlobalLightDir\", cachedGlobalLightDir);\r\n        customShader->SetVec3(\"uGlobalLightColor\", cachedGlobalLightColor);\r\n        customShader->SetFloat(\"uGlobalLightIntensity\", cachedGlobalLightIntensity);\r\n        customShader->SetFloat(\"uAmbient\", cachedAmbient);\r\n    } else {\r\n        if (useDeferred && deferredGeomShader) {\r\n            UseShaderProgram(deferredGeomShader);\r\n            glUniformMatrix4fv(glGetUniformLocation(deferredGeomShader, \"uModel\"), 1, GL_FALSE, glm::value_ptr(model));\r\n            glUniformMatrix4fv(glGetUniformLocation(deferredGeomShader, \"uMVP\"), 1, GL_FALSE, glm::value_ptr(mvp));\r\n            glUniform4fv(glGetUniformLocation(deferredGeomShader, \"uColor\"), 1, glm::value_ptr(color));\r\n            glUniform1f(glGetUniformLocation(deferredGeomShader, \"uAlpha\"), alpha);\r\n\r\n            // Verifica se tem textura\r\n            bool hasTex = obj && !obj->texturePath.empty();\r\n            glUniform1i(glGetUniformLocation(deferredGeomShader, \"uHasTex\"), hasTex ? 1 : 0);\r\n            if (hasTex) {\r\n                GLuint tex = this->LoadTexture(obj->texturePath);\r\n                glActiveTexture(GL_TEXTURE0);\r\n                glBindTexture(GL_TEXTURE_2D, tex);\r\n                glUniform1i(glGetUniformLocation(deferredGeomShader, \"uTex\"), 0);\r\n            }\r\n            glUniform1f(glGetUniformLocation(deferredGeomShader, \"uMetallic\"), obj ? obj->metallic : 0.0f);\r\n            glUniform1f(glGetUniformLocation(deferredGeomShader, \"uRoughness\"), obj ? obj->roughness : 0.5f);\r\n\r\n            glUniform1i(glGetUniformLocation(deferredGeomShader, \"uSpriteAtlasEnabled\"), obj ? (obj->spriteAtlasEnabled ? 1 : 0) : 0);\r\n            glUniform1i(glGetUniformLocation(deferredGeomShader, \"uSpriteCols\"), obj ? obj->spriteCols : 1);\r\n            glUniform1i(glGetUniformLocation(deferredGeomShader, \"uSpriteRows\"), obj ? obj->spriteRows : 1);\r\n            glUniform1i(glGetUniformLocation(deferredGeomShader, \"uSpriteIndex\"), obj ? obj->spriteIndex : 0);\r\n        } else {\r\n            UseShaderProgram(shaderProg);\r\n            BindMaterial(obj);\r\n            SetTransforms(model, mvp);\r\n            glUniform4fv(GetUniform(shaderProg, \"uColor\"), 1, glm::value_ptr(color));\r\n            glUniform1f(GetUniform(shaderProg, \"uAlpha\"), alpha);\r\n        }\r\n    }\r\n\r\n    mesh.Draw();\r\n\r\n    if (obj && obj->isTriggerItem) {\r\n        DrawWireColor(mesh, mvp, glm::vec4(0.2f, 1.0f, 0.2f, 1.0f));\r\n    } else if (selected) {\r\n        DrawWire(mesh, mvp);\r\n    }\r\n}\r\n\r\nstatic GLuint CompileStage(GLenum type, const char* src) {\r\n    GLuint s = glCreateShader(type);\r\n    glShaderSource(s, 1, &src, nullptr);\r\n    glCompileShader(s);\r\n\r\n    GLint ok;\r\n    glGetShaderiv(s, GL_COMPILE_STATUS, &ok);\r\n\r\n    if (!ok) {\r\n        char log[1024];\r\n        glGetShaderInfoLog(","has_more":true,"n":8192,"o":0}
