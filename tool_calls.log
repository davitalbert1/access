PopupTimer = 0.0f;\r\n    std::string activeAchievementName = \"\";\r\n\r\n    void LoadUI();\r\n    void UnloadUI();\r\n    void UpdateUIScripts(float dt);\r\n\r\n    // Luz global\r\n    glm::vec3 globalLightColor{1.0f, 1.0f, 0.95f};\r\n    float globalLightIntensity = 0.85f;\r\n    glm::vec3 globalLightDir{-0.3f, -1.0f, -0.5f};\r\n    float globalAmbient = 0.25f;\r\n\r\n    // Global wind\r\n    glm::vec3 globalWindDir{1.0f, 0.0f, 0.0f};\r\n    float globalWindStrength = 0.0f;\r\n\r\n    std::vector<std::shared_ptr<SceneObject>> objects;\r\n    bool is2D = false;\r\n\r\n    SceneObject* PickObject(const glm::vec3& rayOrigin, const glm::vec3& rayDir);\r\n    bool PickPosition(const glm::vec3& rayOrigin, const glm::vec3& rayDir, glm::vec3& outPos);\r\n\r\n    float GetGridSize() const {\r\n        return gridSize;\r\n    }\r\n    std::shared_ptr<Object3D> AddCube();\r\n    std::shared_ptr<Object3D> AddSphere();\r\n    std::shared_ptr<Object3D> AddPlane();\r\n    std::shared_ptr<SceneObject> selected;\r\n    std::vector<std::shared_ptr<SceneObject>> selectedObjects;\r\n\r\n    bool IsSelected(const std::shared_ptr<SceneObject>& obj) const;\r\n    void ClearSelection();\r\n    void Select(const std::shared_ptr<SceneObject>& obj, bool append = false);\r\n    void Deselect(const std::shared_ptr<SceneObject>& obj);\r\n\r\n    std::shared_ptr<SceneObject> AddSprite();\r\n    std::shared_ptr<CameraObject> AddCamera();\r\n    std::shared_ptr<LightObject> AddLight();\r\n    std::shared_ptr<ParticleObject> AddParticles();\r\n\r\n    void RemoveSelected();\r\n\r\n    void Save(const std::string& path);\r\n    void Load(const std::string& path);\r\n\r\n    json SaveState() const;\r\n    void LoadState(const json& state);\r\n\r\n    // Update\r\n    void UpdateAnimations(float dt);\r\n    void CallScriptUpdate(float dt);\r\n    void ProcessInputs(float dt);\r\n    void ProcessFollow(float dt);\r\n    void ProcessAction(InputAction action, bool pressed);\r\n    void AddObject(co