[2026-06-28 15:14:40] TOOL CALL | func=read_file | args={"path":"E:/engine/src/Graphics/RHI/RHIFactory.cpp"} | result={"c":"#include \"../../../include/Graphics/RHI/IRHIDevice.h\"\r\n#include <fstream>\r\n#include <filesystem>\r\n#include <nlohmann/json.hpp>\r\n\r\nstd::shared_ptr<IRHIDevice> g_RHIDevice = nullptr;\r\n\r\nstd::shared_ptr<IRHIDevice> CreateRHIDevice(RHIType type) {\r\n    switch (type) {\r\n        case RHIType::OpenGL: return CreateOpenGLDevice();\r\n        case RHIType::Vulkan: return CreateVulkanDevice();\r\n        case RHIType::DirectX: return CreateDirectXDevice();\r\n        case RHIType::Metal: return CreateMetalDevice();\r\n    }\r\n    return nullptr;\r\n}\r\n\r\nRHIType LoadPreferredRHI() {\r\n    std::string path = \"engine_settings.json\";\r\n    nlohmann::json j;\r\n    if (std::filesystem::exists(path)) {\r\n        try {\r\n            std::ifstream file(path);\r\n            file >> j;\r\n            if (j.contains(\"renderer\")) {\r\n                std::string r = j[\"renderer\"];\r\n                if (r == \"OpenGL\") return RHIType::OpenGL;\r\n                if (r == \"Vulkan\") return RHIType::Vulkan;\r\n                if (r == \"DirectX\") return RHIType::DirectX;\r\n                if (r == \"Metal\") return RHIType::Metal;\r\n            }\r\n        } catch (...) {}\r\n    } else {\r\n        j[\"renderer\"] = \"OpenGL\";\r\n        try {\r\n            std::ofstream file(path);\r\n            file << j.dump(4);\r\n        } catch (...) {}\r\n    }\r\n    return RHIType::OpenGL;\r\n}\r\n\r\nvoid SavePreferredRHI(RHIType type) {\r\n    std::string path = \"engine_settings.json\";\r\n    nlohmann::json j;\r\n    std::string r = \"OpenGL\";\r\n    if (type == RHIType::Vulkan) r = \"Vulkan\";\r\n    else if (type == RHIType::DirectX) r = \"DirectX\";\r\n    else if (type == RHIType::Metal) r = \"Metal\";\r\n    j[\"renderer\"] = r;\r\n    try {\r\n        std::ofstream file(path);\r\n        file << j.dump(4);\r\n    } catch (...) {}\r\n}\r\n","has_more":false,"n":1752,"o":0}
